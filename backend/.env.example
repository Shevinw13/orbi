# ============================================
# REQUIRED — App won't start without these
# ============================================

# Supabase — get from https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# JWT Secret — any random string (used to sign auth tokens)
JWT_SECRET=your-jwt-secret-key

# ============================================
# OPTIONAL — App works without these
# ============================================

# Upstash Redis — leave empty to use in-memory cache fallback
# Get from https://console.upstash.com
UPSTASH_REDIS_URL=

# Foursquare Places API — leave empty to use free OpenTripMap instead
# Get from https://foursquare.com/developers
FOURSQUARE_API_KEY=

# Google Places (DEPRECATED — replaced by Nominatim for search, Foursquare/OpenTripMap for places)
GOOGLE_PLACES_API_KEY=
